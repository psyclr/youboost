# Abort the commit if ANY check below fails.
set -e

echo "Running pre-commit checks..."

# Format (prettier, shared config) on all staged files + backend eslint/jest on
# staged backend files. Frontend/blog-engine are linted per-package below.
echo "Linting staged files..."
npm run lint-staged

STAGED=$(git diff --cached --name-only)

# Backend (repo root) — only when its sources/config changed.
if echo "$STAGED" | grep -qE '^(src/|tsconfig|prisma/|jest|eslint)'; then
  echo "Backend: type check + circular deps..."
  npm run typecheck
  npx madge --circular --extensions ts src/
fi

# Frontend workspace.
if echo "$STAGED" | grep -q '^frontend/'; then
  echo "Frontend: lint + type check..."
  npm run -w frontend lint
  npm run -w frontend typecheck
fi

# blog-engine workspace.
if echo "$STAGED" | grep -q '^blog-engine/'; then
  echo "blog-engine: lint + type check..."
  npm run -w blog-engine lint
  npm run -w blog-engine typecheck
fi

# Unused code across all workspaces.
echo "Checking for unused code..."
npm run knip

echo "Checking documentation..."
./scripts/update-claude-docs.sh pre-commit

echo "All pre-commit checks passed!"
