# Blog Engine — Environment Variables
# Copy to .env and fill in values

# Database (separate from youboost!)
DATABASE_URL=postgresql://youboost:youboost_dev_password@localhost:5432/blog_engine_dev

# Redis (own instance, separate from youboost)
REDIS_URL=redis://localhost:6380

# Claude API (default LLM provider)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (optional — fallback for sites using OPENAI provider without own credential)
# OPENAI_API_KEY=sk-...

# Unsplash (optional, for cover images)
UNSPLASH_ACCESS_KEY=...

# Server
PORT=3200
HOST=0.0.0.0

# Youboost webhook for ISR revalidation
YOUBOOST_REVALIDATE_URL=http://localhost:3101/api/revalidate/blog
YOUBOOST_REVALIDATE_SECRET=change-me

# Skip domain DNS verification in dev
SKIP_DOMAIN_VERIFY=true
