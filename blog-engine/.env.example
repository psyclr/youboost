# Blog Engine — Environment Variables
# Copy to .env and fill in values

# Shared youboost Postgres, isolated in the `blog` schema (not youboost's `public`)
DATABASE_URL=postgresql://youboost:youboost_dev_password@localhost:5432/youboost_dev?schema=blog

# Shared youboost Redis; BullMQ queues are namespaced blog:* (queue wiring is iter 4)
REDIS_URL=redis://localhost:6379

# LLM — currently required by config (iteration 4 switches the default to OpenAI/Codex)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Unsplash (optional, for cover images)
UNSPLASH_ACCESS_KEY=...

# Server
PORT=3200
HOST=0.0.0.0

# Youboost webhook for ISR revalidation
YOUBOOST_REVALIDATE_URL=http://localhost:3101/api/revalidate/blog
YOUBOOST_REVALIDATE_SECRET=change-me

# Skip domain DNS verification in dev
SKIP_DOMAIN_VERIFY=true
