{
  "name": "youboost-panel",
  "version": "0.1.0-alpha",
  "description": "youboost SMM Marketplace Platform",
  "main": "dist/index.js",
  "workspaces": [
    "frontend",
    "blog-engine"
  ],
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:all": "jest --coverage --verbose",
    "test:changed": "jest --onlyChanged",
    "test:unit": "jest --testPathPattern=\\.test\\.ts$",
    "test:integration": "jest --testPathPattern=\\.integration\\.ts$",
    "test:e2e": "jest --config jest.e2e.config.js --runInBand --forceExit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint-staged": "lint-staged",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "knip": "NODE_OPTIONS=--experimental-require-module knip --no-progress",
    "build": "tsc",
    "validate": "npm run lint && npm run typecheck && npm run test",
    "quality": "bash scripts/quality-check.sh",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "start:dev": "ts-node src/index.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "prepare": "husky"
  },
  "keywords": [
    "smm",
    "youtube",
    "marketplace",
    "api"
  ],
  "author": "Alexander",
  "license": "MIT",
  "type": "commonjs",
  "overrides": {
    "ioredis": "$ioredis"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^9.39.2",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unicorn": "^69.0.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "knip": "^6.21.0",
    "lint-staged": "^17.0.8",
    "madge": "^8.0.0",
    "openapi-types": "^12.1.3",
    "prettier": "^3.8.5",
    "prisma": "^7.8.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "google-auth-library": "^10.9.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "stripe": "^22.3.0",
    "zod": "^4.4.3"
  }
}
