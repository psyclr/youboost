{
  "workspaces": {
    ".": {
      "entry": ["src/shared/health/index.ts", "eslint.base.mjs"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@prisma/client", "pino-pretty"],
      "ignoreBinaries": ["docker-compose"]
    },
    "frontend": {
      "entry": ["src/app/**/page.tsx", "src/app/**/layout.tsx"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@testing-library/*", "tw-animate-css", "shadcn", "tailwindcss"]
    },
    "blog-engine": {
      "entry": ["src/server.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@prisma/client", "ioredis", "@anthropic-ai/sdk", "openai"]
    }
  },
  "ignore": ["frontend/src/components/ui/**", "blog-engine/src/ai/**"],
  "ignoreExportsUsedInFile": true,
  "ignoreIssues": {
    "src/modules/**/*.types.ts": ["exports", "types"],
    "src/modules/billing/providers/registry.ts": ["exports"],
    "src/shared/queue/queue.ts": ["exports"],
    "src/modules/notifications/utils/email-templates.ts": ["exports"],
    "src/modules/notifications/utils/email-provider-factory.ts": ["exports"],
    "frontend/src/lib/api/**": ["exports", "types"],
    "frontend/src/lib/landings/calculator.ts": ["exports"]
  },
  "rules": {
    "unlisted": "off"
  }
}
