#!/bin/bash
# SUPERSEDED: This legacy script is NOT triggered by Claude Code.
# Claude Code hooks are now configured in .claude/settings.local.json.
# Kept for reference only.
#
# Original description: Триггерится когда Claude завершает задачу

# Load configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/config.sh" ]; then
    source "$SCRIPT_DIR/config.sh"
fi

TASK_DESCRIPTION=$1
SUCCESS=$2  # true/false

echo "✅ Task completed: $TASK_DESCRIPTION (success: $SUCCESS)"

if [[ $SUCCESS == "true" ]]; then
    # 1. Запустить финальные проверки
    if [ -f "package.json" ]; then
        echo "🔍 Running validation..."
        npm run validate 2>/dev/null || echo "⚠️  Validation failed or not configured yet"
    fi

    # 2. Обновить .claude.md секцию "📝 Недавние изменения"
    if [ -f ".claude.md" ]; then
        DATE=$(date +%Y-%m-%d)
        COMMIT_HASH=$(git log -1 --pretty=%h 2>/dev/null || echo "no-commit")
        # Добавляем запись в начало секции "Недавние изменения"
        TEMP_FILE=".claude.md.tmp"
        awk -v date="$DATE" -v hash="$COMMIT_HASH" -v desc="$TASK_DESCRIPTION" '
            /## 📝 Недавние изменения/ {
                print $0
                print ""
                print "- [" date "] (" hash ") " desc
                next
            }
            { print }
        ' .claude.md > "$TEMP_FILE" && mv "$TEMP_FILE" .claude.md
    fi

    # 3. Обновить задачу в Linear
    if [ "$ENABLE_LINEAR" = true ] && [ -n "$LINEAR_ISSUE_ID" ]; then
        echo "✓ Updating Linear issue to Done..."
        claude mcp linear update-issue \
            --issue-id "$LINEAR_ISSUE_ID" \
            --state "Done" 2>/dev/null || echo "ℹ️  Linear issue ID not set"
    fi

    # 4. Создать GitHub issue с резюме (опционально)
    if [ "$ENABLE_GITHUB" = true ] && [ -n "$GITHUB_REPO" ]; then
        echo "📝 Creating GitHub completion issue..."
        ISSUE_BODY="Task completed successfully

## Description
$TASK_DESCRIPTION

## Timestamp
$(date)

🤖 Auto-generated by Claude Code hooks"

        claude mcp github create-issue \
            --repo "$GITHUB_REPO" \
            --title "✅ Completed: $TASK_DESCRIPTION" \
            --body "$ISSUE_BODY" \
            --labels "enhancement,completed" 2>/dev/null && echo "✓ GitHub issue created" || echo "ℹ️  GitHub repo not configured"
    fi

    # 5. Предложить создать commit
    echo ""
    echo "🎉 Task completed successfully!"
    echo "📝 Ready to commit? Use: git add . && git commit -m \"feat: $TASK_DESCRIPTION\""
else
    echo "❌ Task failed. Review errors and try again."

    # Создать GitHub issue для failed task
    if [ "$ENABLE_GITHUB" = true ] && [ "$AUTO_CREATE_BUG_ISSUES" = true ] && [ -n "$GITHUB_REPO" ]; then
        echo "🐛 Creating GitHub issue for failed task..."
        ISSUE_BODY="Task failed and needs investigation

## Task Description
$TASK_DESCRIPTION

## Timestamp
$(date)

🤖 Auto-generated by Claude Code hooks"

        claude mcp github create-issue \
            --repo "$GITHUB_REPO" \
            --title "🐛 Failed: $TASK_DESCRIPTION" \
            --body "$ISSUE_BODY" \
            --labels "bug,needs-investigation" 2>/dev/null && echo "✓ Bug issue created"
    fi
fi
